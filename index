<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Unlock the Topic</title>
    <style>
        /* Base styles and fonts - Hacker/Tech Theme */
        @import url('https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600;700&display=swap');
        
        body {
            font-family: 'Fira Code', monospace;
            background: #050914; /* Dark navy / black */
            background-image: radial-gradient(circle at center, #0a1128 0%, #02040a 100%);
            min-height: 100vh;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #ffffff; /* White text */
        }

        /* Main game container styling */
        .game-container {
            background: rgba(10, 15, 30, 0.8);
            border: 2px solid #00CFFF; /* Neon Blue */
            border-radius: 15px;
            padding: 40px;
            box-shadow: 0 0 20px rgba(0, 207, 255, 0.2), inset 0 0 15px rgba(0, 207, 255, 0.1);
            max-width: 650px;
            width: 90%;
            text-align: center;
            backdrop-filter: blur(5px);
        }

        h1 {
            color: #00CFFF;
            text-shadow: 0 0 10px #00CFFF, 0 0 20px #00CFFF;
            font-size: 2.5rem;
            margin-top: 0;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        /* New Instructions Box Styling */
        .instructions-box {
            background: rgba(0, 207, 255, 0.05);
            border: 1px solid rgba(0, 207, 255, 0.3);
            border-radius: 8px;
            padding: 15px 20px;
            margin-bottom: 25px;
            text-align: left;
            font-size: 0.95rem;
            color: #e0e0e0;
            line-height: 1.5;
        }

        .instructions-box p {
            margin: 0 0 10px 0;
            color: #00CFFF;
            letter-spacing: 1px;
        }

        .instructions-box ol {
            margin: 0;
            padding-left: 20px;
        }

        .instructions-box li {
            margin-bottom: 8px;
        }

        /* Highlight classes for the problem text */
        .known-val {
            color: #00CFFF;
            text-shadow: 0 0 5px rgba(0, 207, 255, 0.5);
            font-weight: 700;
        }

        .compute-val {
            color: #39FF14;
            text-shadow: 0 0 5px rgba(57, 255, 20, 0.5);
            font-weight: 700;
        }

        /* Hidden word letter boxes */
        .word-board {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

        .letter-box {
            width: 50px;
            height: 60px;
            background: #000000;
            border: 2px solid #9D4EDD; /* Secondary Purple */
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            font-weight: 700;
            color: #9D4EDD;
            text-shadow: 0 0 8px #9D4EDD;
            box-shadow: 0 0 10px rgba(157, 78, 221, 0.3);
            text-transform: uppercase;
            transition: all 0.3s ease;
        }

        /* Animation class added when a letter is revealed */
        .letter-box.revealed {
            background: rgba(57, 255, 20, 0.1);
            border-color: #39FF14; /* Accent Neon Green */
            color: #39FF14;
            text-shadow: 0 0 10px #39FF14;
            box-shadow: 0 0 15px rgba(57, 255, 20, 0.4), inset 0 0 10px rgba(57, 255, 20, 0.2);
            animation: glitchPop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @keyframes glitchPop {
            0% { transform: scale(0.5); opacity: 0; filter: hue-rotate(90deg); }
            50% { transform: scale(1.1); filter: hue-rotate(-90deg); }
            100% { transform: scale(1); opacity: 1; filter: hue-rotate(0deg); }
        }

        /* Question area styling */
        .question-card {
            background: rgba(0, 0, 0, 0.5);
            border-radius: 10px;
            padding: 20px;
            margin-bottom: 20px;
            border: 1px solid #9D4EDD;
            box-shadow: inset 0 0 15px rgba(157, 78, 221, 0.1);
        }

        #question-counter {
            font-size: 0.9rem;
            color: #39FF14; /* Neon Green */
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 5px #39FF14;
        }

        #question-text {
            font-size: 1.15rem;
            font-weight: 600;
            margin: 15px 0;
            color: #ffffff;
            white-space: pre-line;
            text-shadow: 0 0 3px rgba(255, 255, 255, 0.5);
            line-height: 1.5;
            text-align: justify;
        }

        /* Input fields and buttons */
        input {
            font-family: inherit;
            font-size: 1.2rem;
            padding: 10px 15px;
            background: #02040a;
            color: #00CFFF;
            border: 2px solid #00CFFF;
            border-radius: 5px;
            width: 150px;
            text-align: center;
            outline: none;
            transition: all 0.3s ease;
            box-shadow: inset 0 0 5px rgba(0, 207, 255, 0.2);
        }

        input:focus {
            box-shadow: 0 0 15px rgba(0, 207, 255, 0.5), inset 0 0 10px rgba(0, 207, 255, 0.3);
        }
        
        input::placeholder {
            color: rgba(0, 207, 255, 0.3);
        }

        button {
            font-family: inherit;
            font-size: 1.1rem;
            font-weight: bold;
            padding: 10px 20px;
            background: transparent;
            border-radius: 5px;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s;
        }

        button:active {
            transform: scale(0.95);
        }

        .btn-submit {
            border: 2px solid #00CFFF;
            color: #00CFFF;
            box-shadow: 0 0 10px rgba(0, 207, 255, 0.2);
            margin-left: 10px;
        }

        .btn-submit:hover {
            background-color: #00CFFF;
            color: #000;
            box-shadow: 0 0 20px #00CFFF;
        }

        .btn-guess {
            border: 2px solid #9D4EDD;
            color: #9D4EDD;
            box-shadow: 0 0 10px rgba(157, 78, 221, 0.2);
            margin-left: 10px;
        }

        .btn-guess:hover {
            background-color: #9D4EDD;
            color: #000;
            box-shadow: 0 0 20px #9D4EDD;
        }

        .btn-reset {
            border: 2px solid #ff003c;
            color: #ff003c;
            margin-top: 20px;
            box-shadow: 0 0 10px rgba(255, 0, 60, 0.2);
        }

        .btn-reset:hover {
            background-color: #ff003c;
            color: #000;
            box-shadow: 0 0 20px #ff003c;
        }

        /* Feedback messages (Correct / Try Again) */
        #feedback-message {
            font-size: 1.2rem;
            font-weight: bold;
            margin-top: 15px;
            min-height: 25px;
        }

        .correct { 
            color: #39FF14; 
            text-shadow: 0 0 10px #39FF14;
        }
        .incorrect { 
            color: #ff003c; 
            text-shadow: 0 0 10px #ff003c;
            animation: shake 0.4s; 
        }

        @keyframes shake {
            0% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            50% { transform: translateX(5px); }
            75% { transform: translateX(-5px); }
            100% { transform: translateX(0); }
        }

        /* Bonus section layout */
        .bonus-section {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 2px dashed #9D4EDD;
        }
    </style>
</head>
<body>

    <div class="game-container">
        <h1>Unlock the Topic!</h1>
        
        <div class="instructions-box">
            <p><strong>Game Instructions:</strong></p>
            <ol>
                <li>Read the given scenario carefully.</li>
                <li>You will see specific names with assigned values (e.g., <span class="known-val">price</span>&nbsp;=&nbsp;50). Substitute these known numbers to calculate the unknown amount.</li>
                <li>Type your final calculated number in the box and submit to unlock a letter!</li>
            </ol>
        </div>

        <!-- Area where the hidden letters will be displayed -->
        <div id="word-board" class="word-board">
            <!-- Letter boxes will be injected here by JavaScript -->
        </div>

        <!-- Area for the current question -->
        <div id="question-card" class="question-card">
            <div id="question-counter">Question 1 of 8</div>
            <p id="question-text">Loading question...</p>
            
            <div id="input-area">
                <input type="number" id="answer-input" placeholder="Answer" onkeydown="handleEnter(event, 'submit')">
                <button class="btn-submit" onclick="submitAnswer()">Submit</button>
            </div>
            
            <p id="feedback-message"></p>
        </div>

        <!-- Bonus feature: Guess the entire topic at once -->
        <div class="bonus-section" id="bonus-section">
            <p>Know the answer already?</p>
            <input type="text" id="guess-input" placeholder="Guess the topic" onkeydown="handleEnter(event, 'guess')">
            <button class="btn-guess" onclick="guessTopic()">Guess Topic</button>
        </div>

        <!-- Restart the game -->
        <button class="btn-reset" onclick="resetGame()">Restart Game</button>
    </div>

    <script>
        /**
         * Game Configuration and Data
         * We define the hidden topic and the list of questions here.
         * The topic word is kept secret in the background logic!
         */
        const targetWord = "VARIABLE"; // Shhh! This is the secret topic.
        
        // Array of objects, each containing a scenario and the correct numeric answer.
        // We use HTML tags to colorize specific words and &nbsp; to prevent awkward line breaks.
        const questions = [
            {
                scenario: "After school, Ana went to the bookstore to buy supplies.<br>If <span class='known-val'>allowance</span>&nbsp;=&nbsp;100, <span class='known-val'>notebookPrice</span>&nbsp;=&nbsp;20, <span class='known-val'>notebooksBought</span>&nbsp;=&nbsp;4,<br>compute <span class='compute-val'>remainingMoney</span>.",
                answer: 20
            },
            {
                scenario: "Marco worked part-time during the weekend to save money.<br>If <span class='known-val'>dailyWage</span>&nbsp;=&nbsp;300, <span class='known-val'>daysWorked</span>&nbsp;=&nbsp;5, <span class='known-val'>expenses</span>&nbsp;=&nbsp;1200,<br>compute <span class='compute-val'>totalSavings</span>.",
                answer: 300
            },
            {
                scenario: "Lia rides a jeepney to and from school every day.<br>If <span class='known-val'>fare</span>&nbsp;=&nbsp;15, <span class='known-val'>ridesPerDay</span>&nbsp;=&nbsp;2, <span class='known-val'>days</span>&nbsp;=&nbsp;6,<br>compute <span class='compute-val'>totalFare</span>.",
                answer: 180
            },
            {
                scenario: "During a short quiz in class, Carlo checked his score.<br>If <span class='known-val'>quizScore</span>&nbsp;=&nbsp;8, <span class='known-val'>totalItems</span>&nbsp;=&nbsp;10,<br>compute <span class='compute-val'>incorrectAnswers</span>.",
                answer: 2
            },
            {
                scenario: "During a hot day, Bea made sure to stay hydrated.<br>If <span class='known-val'>waterPerBottle</span>&nbsp;=&nbsp;500, <span class='known-val'>bottlesDrunk</span>&nbsp;=&nbsp;3,<br>compute <span class='compute-val'>totalWaterIntake</span> (in mL).",
                answer: 1500
            },
            {
                scenario: "Jared used his prepaid load to send messages to his groupmates.<br>If <span class='known-val'>load</span>&nbsp;=&nbsp;50, <span class='known-val'>textCost</span>&nbsp;=&nbsp;1, <span class='known-val'>textsSent</span>&nbsp;=&nbsp;18,<br>compute <span class='compute-val'>remainingLoad</span>.",
                answer: 32
            },
            {
                scenario: "In PE class, students tracked their movement during an activity.<br>If <span class='known-val'>stepsPerLap</span>&nbsp;=&nbsp;200, <span class='known-val'>laps</span>&nbsp;=&nbsp;4,<br>compute <span class='compute-val'>totalSteps</span>.",
                answer: 800
            },
            {
                scenario: "Mika prepared for exams by reviewing a little each day.<br>If <span class='known-val'>studyHoursPerDay</span>&nbsp;=&nbsp;2, <span class='known-val'>days</span>&nbsp;=&nbsp;5,<br>compute <span class='compute-val'>totalStudyHours</span>.",
                answer: 10
            }
        ];

        // State variables to track the player's progress
        let currentQuestionIndex = 0;
        let revealedLetters = new Array(targetWord.length).fill(false);
        let isGameWon = false;
        let shuffledIndices = []; // Array to hold randomized letter reveal order

        /**
         * Initialize the game setup when the page loads
         */
        function initGame() {
            currentQuestionIndex = 0;
            revealedLetters = new Array(targetWord.length).fill(false);
            isGameWon = false;
            
            // Create an array [0, 1, 2, 3, 4, 5, 6, 7] and shuffle it
            shuffledIndices = [];
            for (let i = 0; i < targetWord.length; i++) {
                shuffledIndices.push(i);
            }
            // Fisher-Yates Shuffle algorithm to randomize the array
            for (let i = shuffledIndices.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [shuffledIndices[i], shuffledIndices[j]] = [shuffledIndices[j], shuffledIndices[i]];
            }
            
            // Reset UI elements
            document.getElementById("question-card").style.display = "block";
            document.getElementById("bonus-section").style.display = "block";
            document.getElementById("feedback-message").textContent = "";
            document.getElementById("answer-input").value = "";
            document.getElementById("guess-input").value = "";
            
            renderWordBoard();
            displayCurrentQuestion();
        }

        /**
         * Renders the hidden word dashes or revealed letters onto the screen
         */
        function renderWordBoard() {
            const board = document.getElementById("word-board");
            board.innerHTML = ""; // Clear existing boxes

            // Loop through each letter in our target word
            for (let i = 0; i < targetWord.length; i++) {
                const letterBox = document.createElement("div");
                letterBox.className = "letter-box";
                
                // If the letter at this index is solved, show it and add the green class
                if (revealedLetters[i]) {
                    letterBox.textContent = targetWord[i];
                    letterBox.classList.add("revealed");
                } else {
                    letterBox.textContent = "_";
                }
                
                board.appendChild(letterBox);
            }
        }

        /**
         * Updates the text of the current question on the screen
         */
        function displayCurrentQuestion() {
            if (currentQuestionIndex < questions.length) {
                document.getElementById("question-counter").textContent = `Question ${currentQuestionIndex + 1} of ${questions.length}`;
                // Using innerHTML instead of textContent so our color spans render correctly!
                document.getElementById("question-text").innerHTML = questions[currentQuestionIndex].scenario;
                document.getElementById("answer-input").value = "";
                document.getElementById("answer-input").focus();
            } else {
                // If all questions are done but game isn't "won" yet (just a safety fallback)
                winGame();
            }
        }

        /**
         * Checks the student's answer against the correct answer
         */
        function submitAnswer() {
            if (isGameWon) return;

            const inputField = document.getElementById("answer-input");
            const feedbackText = document.getElementById("feedback-message");
            const userAnswer = parseInt(inputField.value);
            const correctAnswer = questions[currentQuestionIndex].answer;

            // Clear previous animation by removing and re-adding the element slightly later
            feedbackText.classList.remove("incorrect", "correct");
            void feedbackText.offsetWidth; // Trigger reflow to restart CSS animation

            if (isNaN(userAnswer)) {
                feedbackText.textContent = "Please enter a number!";
                feedbackText.className = "incorrect";
                return;
            }

            if (userAnswer === correctAnswer) {
                // Correct Answer!
                feedbackText.textContent = "Correct! Great job!";
                feedbackText.className = "correct";
                
                // Reveal a randomized letter using our shuffled indices
                const letterIndexToReveal = shuffledIndices[currentQuestionIndex];
                revealedLetters[letterIndexToReveal] = true;
                renderWordBoard();

                // Move to next question after a short delay so they can see the "Correct!" message
                setTimeout(() => {
                    currentQuestionIndex++;
                    feedbackText.textContent = "";
                    if (currentQuestionIndex < questions.length) {
                        displayCurrentQuestion();
                    } else {
                        winGame();
                    }
                }, 1500);

            } else {
                // Incorrect Answer
                feedbackText.textContent = "Try again! You can do it.";
                feedbackText.className = "incorrect";
            }
        }

        /**
         * Checks if the student correctly guessed the whole topic early
         */
        function guessTopic() {
            if (isGameWon) return;

            const guessInput = document.getElementById("guess-input");
            const feedbackText = document.getElementById("feedback-message");
            const userGuess = guessInput.value.trim().toUpperCase();

            feedbackText.classList.remove("incorrect", "correct");
            void feedbackText.offsetWidth; // Trigger reflow

            if (userGuess === targetWord) {
                // If they guess right, reveal everything and win
                revealedLetters.fill(true);
                renderWordBoard();
                winGame();
            } else {
                feedbackText.textContent = "Not quite the topic! Keep trying.";
                feedbackText.className = "incorrect";
            }
        }

        /**
         * Handles the Enter key press for input fields
         */
        function handleEnter(event, type) {
            if (event.key === "Enter") {
                if (type === 'submit') submitAnswer();
                if (type === 'guess') guessTopic();
            }
        }

        /**
         * Triggers the win state, hiding questions and showing a congratulation
         */
        function winGame() {
            isGameWon = true;
            document.getElementById("question-card").style.display = "none";
            document.getElementById("bonus-section").style.display = "none";
            
            // Create a nice victory message
            const container = document.querySelector(".game-container");
            const victoryMsg = document.createElement("div");
            victoryMsg.id = "victory-message";
            victoryMsg.innerHTML = `
                <h2 style="color: #39FF14; text-shadow: 0 0 15px #39FF14; font-size: 2.2rem; margin-top: 20px; text-transform: uppercase;">TOPIC UNLOCKED!</h2>
                <p style="font-size: 1.15rem; color: #00CFFF; text-shadow: 0 0 5px rgba(0, 207, 255, 0.5); line-height: 1.6; text-align: justify;">You have successfully unlocked today’s topic: <strong>JavaScript Variables</strong>. Variables are containers used to store and manage data in a program, allowing programmers to save, access, and update information when needed. Today, we will explore how variables help create interactive and dynamic websites.</p>
            `;
            
            // Only append if it doesn't exist yet to prevent duplicates
            if (!document.getElementById("victory-message")) {
                container.insertBefore(victoryMsg, document.querySelector(".btn-reset"));
            }
        }

        /**
         * Resets the entire game to start over
         */
        function resetGame() {
            const victoryMsg = document.getElementById("victory-message");
            if (victoryMsg) {
                victoryMsg.remove();
            }
            initGame();
        }

        // Start the game immediately when the script runs
        window.onload = initGame;
    </script>
</body>
</html>
